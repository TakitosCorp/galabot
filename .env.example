# --- Discord ---
DISCORD_TOKEN=your_discord_bot_token
DISCORD_ID=your_discord_application_id
GALA_DISCORD_ID=your_bot_user_id
DISCORD_NOTIFICATION_CHANNEL=your_notification_channel_id
DISCORD_NOTIFICATION_ROLE_ID=your_role_id_or_leave_blank
SPANISH_CHANNEL_ID=your_spanish_channel_id

# --- Twitch ---
TWITCH_CHANNEL=your_twitch_channel_name
TWITCH_USERNAME=your_twitch_username

# --- YouTube ---
YOUTUBE_CHANNEL_ID=your_youtube_channel_id
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_API_KEY_2=optional_fallback_api_key

# --- Webhooks ---
POST_DATA_WEBHOOK=https://your-webhook-url

# --- Platform toggles (set to "false" to disable) ---
ENABLE_DISCORD=true
ENABLE_TWITCH=true
ENABLE_YOUTUBE=true

# --- Puppeteer ---
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
